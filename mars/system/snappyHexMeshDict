FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      snappyHexMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

castellatedMesh true;
snap            true;
addLayers       false;

geometry
{
    mars.stl
    {
        type triSurfaceMesh;
        name Mars;
    }
}

castellatedMeshControls
{
    maxLocalCells   1000000;
    maxGlobalCells  5000000;
    minRefinementCells 10;
    nCellsBetweenLevels 3;
    resolveFeatureAngle 30;
    allowFreeStandingZoneFaces  true;
    useGap                      false;

    refinementSurfaces
    {
        Mars
        {
            level (6 7); 
            patchInfo { type wall; }
        }
    }

    features
    (
        { file "mars.eMesh"; level 7; }
    );

    refinementRegions
    {
        refinementBox
        {
            mode distance;
            levels ((0.05 6) (0.2 5) (0.5 4)); 
        }
    }

    locationInMesh (0 0 0); 
}

snapControls
{
    nSmoothPatch         5;
    nSmoothInternal      15;
    tolerance            2.0;
    nSolveIter           100; 
    nRelaxIter           8;   
    nFeatureSnapIter     15;  
    nFaceSplitInterval   1;

    implicitFeatureSnap false;
    explicitFeatureSnap true;
    multiRegionFeatureSnap false;
}

addLayersControls
{
}

meshQualityControls
{
    maxNonOrtho         65; 
    maxBoundarySkewness 4;
    maxInternalSkewness 2;
    maxConcave          80;

    minArea             1e-13;
    minVol              1e-18;
    minTwist            0.02;
    minFaceWeight       0.02;
    minVolRatio         0.01;
    minTriangleTwist    0.02;
    minDeterminant      0.001;
    
    minTetQuality       1e-9;
    nSmoothScale        20; 
    errorReduction      0.75;
}

mergeTolerance 1e-6;
debug 0;

// ************************************************************************* //